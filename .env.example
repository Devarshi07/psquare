# P Square Environment Variables
# Copy to .env and fill in your values

# ====================
# Gemini API (REQUIRED)
# ====================
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ====================
# WhatsApp - Meta Cloud API
# ====================
# Get from: https://developers.facebook.com/apps/
WHATSAPP_PROVIDER=meta
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=your_verify_token_here

# ====================
# Database - Supabase (recommended for cost)
# ====================
# Get from: https://supabase.com/dashboard
# Local dev: use localhost; Production: use Supabase cloud
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/psquare

# Supabase (optional - for cloud storage when DB is on Supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ====================
# Redis - Upstash (free tier) or local
# ====================
# Local: redis://localhost:6379/0
# Upstash: redis://xxx.upstash.io
REDIS_URL=redis://localhost:6379/0

# ====================
# S3 / Object Storage (optional - for later)
# ====================
# Only needed when you scale up. Use Supabase Storage for now.
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT_URL=
# S3_REGION=ap-south-1

# ====================
# Sentry (optional)
# ====================
# Get from: https://sentry.io
# SENTRY_DSN=

# ====================
# App Config
# ====================
# Local: http://localhost:8000
# Production: https://your-domain.com
APP_BASE_URL=http://localhost:8000

# Mini-app URL (Vercel in production)
MINIAPP_BASE_URL=http://localhost:5173

# JWT secret for mini-app links (generate a secure random string)
MINIAPP_JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Admin phone numbers (for alerts)
ADMIN_PHONE_NUMBERS=+919999999999